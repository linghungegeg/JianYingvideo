SECRET_KEY=your-secret-key-change-in-production
VIDEOFACTORY_KEY_ENCRYPTION_KEY=base64-32-byte-urlsafe-key
DATABASE_URL=
SQLALCHEMY_DATABASE_URI=
DEV_DATABASE_URL=sqlite:///data-runtime.sqlite
REDIS_URL=redis://localhost:6379/0
DEFAULT_USER_QUOTA=5
VF_REMOTE_AUTH_MODE=1
VF_OFFICIAL_SITE_URL=https://www.zysj.site

# Legacy template compatibility
LEGACY_TEMPLATE_ENDPOINTS_ENABLED=1

# Optional feature groups
DUO_FEATURES_ENABLED=1
OPENCLAW_FEATURES_ENABLED=1
MANGA_FEATURES_ENABLED=1
VF_HOST=127.0.0.1
VF_PORT=5000
VF_DEBUG=0
VF_AUTO_MIGRATE=1
VF_OPEN_BROWSER=1
VF_START_PATH=/user
VF_REQUIRE_PRODUCTION_CONFIG=1

# Notes:
# - Suitable for a full-feature desktop / commercial package.
# - Keeps all optional runtime entry points enabled.
