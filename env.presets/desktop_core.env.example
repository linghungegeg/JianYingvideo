SECRET_KEY=your-secret-key-change-in-production
VIDEOFACTORY_KEY_ENCRYPTION_KEY=base64-32-byte-urlsafe-key
DATABASE_URL=mysql+pymysql://USER:PASSWORD@localhost:3306/video_factory
REDIS_URL=redis://localhost:6379/0
DEFAULT_USER_QUOTA=5

# Legacy template compatibility
LEGACY_TEMPLATE_ENDPOINTS_ENABLED=0

# Optional feature groups
DUO_FEATURES_ENABLED=0
OPENCLAW_FEATURES_ENABLED=0
MANGA_FEATURES_ENABLED=0

# Notes:
# - Suitable for a lean local EXE focused on draft_path workflow.
# - Keeps all code in the project, but disables non-core runtime entry points.
