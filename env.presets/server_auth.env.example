SECRET_KEY=your-strong-secret-key-change-in-production
VIDEOFACTORY_KEY_ENCRYPTION_KEY=base64-32-byte-urlsafe-key
DATABASE_URL=mysql+pymysql://USER:PASSWORD@127.0.0.1:3306/video_factory?charset=utf8mb4

LEGACY_TEMPLATE_ENDPOINTS_ENABLED=0
DUO_FEATURES_ENABLED=0
OPENCLAW_FEATURES_ENABLED=0
MANGA_FEATURES_ENABLED=0

VF_HOST=127.0.0.1
VF_PORT=5000
VF_DEBUG=0
VF_AUTO_MIGRATE=1
VF_OPEN_BROWSER=0
VF_START_PATH=/admin
VF_REQUIRE_PRODUCTION_CONFIG=1
VF_ENABLE_MCP_API=0

# Server-side validation only:
# - login/register
# - VIP/quota/CDK/device binding/invite reward
# - resource exchange review
# - admin and account-related APIs
